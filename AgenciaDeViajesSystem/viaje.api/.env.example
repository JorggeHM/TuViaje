DB_HOST=127.0.0.1
DB_NAME=tuviaje_db
DB_USER=root
DB_PASS=
DB_CHARSET=utf8mb4

JWT_SECRET=cambia_este_valor_por_uno_seguro
JWT_TTL=3600
JWT_ALG=HS256

CORS_ORIGIN=http://localhost:5173

# URL pública del frontend — se usa para construir links en emails (bienvenida, reset, etc.)
APP_URL=http://localhost:5173

# SMTP (opcional — si SMTP_HOST está vacío se usa mail() nativo)
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
SMTP_SECURE=tls
MAIL_FROM=no-reply@tuviaje.com
MAIL_FROM_NAME=TuViaje

# ╔══════════════════════════════════════════════════════════════════════════╗
# ║  STRIPE — credenciales del procesador de pagos                           ║
# ╠══════════════════════════════════════════════════════════════════════════╣
# ║  Sin estas dos variables el flujo de pago NO funciona.                   ║
# ║  Documentación completa: AgenciaDeViajesSystem/stripe.md                 ║
# ╚══════════════════════════════════════════════════════════════════════════╝

# ── 1) SECRET KEY ──────────────────────────────────────────────────────────
# Pegá acá la Secret Key de tu cuenta Stripe.
#
# Cómo obtenerla:
#   a) Crear cuenta gratis en https://dashboard.stripe.com/register
#   b) Asegurate de estar en MODO TEST (toggle arriba a la derecha).
#   c) Ir a https://dashboard.stripe.com/test/apikeys
#   d) Copiar la "Secret key" (empieza con sk_test_...).
#
# 👇 PEGAR AQUÍ ABAJO 👇
STRIPE_SECRET_KEY=

# ── 2) WEBHOOK SECRET ──────────────────────────────────────────────────────
# Pegá acá el secret que verifica la firma de los webhooks entrantes.
#
# Cómo obtenerlo en DESARROLLO (con Stripe CLI):
#   a) Instalar Stripe CLI: https://github.com/stripe/stripe-cli/releases
#   b) Loguearse: stripe login
#   c) Arrancar el túnel (dejar corriendo en una terminal aparte):
#        stripe listen --forward-to http://localhost/AgenciaDeViajesSystem/viaje.api/api/stripe/webhook
#   d) Copiar el "Your webhook signing secret is whsec_..." que imprime al arrancar.
#
# Cómo obtenerlo en PRODUCCIÓN:
#   a) Crear endpoint en https://dashboard.stripe.com/webhooks apuntando a tu dominio.
#   b) Suscribirlo a: checkout.session.completed, checkout.session.expired,
#      checkout.session.async_payment_failed, payment_intent.payment_failed.
#   c) Copiar el "Signing secret" del endpoint (también whsec_..., distinto al de CLI).
#
# 👇 PEGAR AQUÍ ABAJO 👇
STRIPE_WEBHOOK_SECRET=
