# ─────────────────────────────────────────────────────────────────────────────
# .env — Variables de entorno para el frontend (Vite)
#
# Todas las variables DEBEN empezar con VITE_ para que Vite las exponga
# en el código como import.meta.env.VITE_NOMBRE_VARIABLE
#
# ⚠️  Este archivo NO debe subirse a git si contiene secretos (tokens, passwords).
#    Agrega .env a tu .gitignore si aún no está.
# ─────────────────────────────────────────────────────────────────────────────

# URL base de la API del backend.
# Destinos.tsx la usa para construir el endpoint de viajes:
#   fetch(`${VITE_API_BASE_URL}/AgenciaDeViajesSystem/API/API_getviajes.php`)
#
# Para apuntar a otro puerto (ej. API en Node/Express):
#   VITE_API_BASE_URL=http://localhost:3000
VITE_API_BASE_URL=http://localhost

# Nombre de la aplicación (disponible como import.meta.env.VITE_APP_NAME)
VITE_APP_NAME=TuViaje
